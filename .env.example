# Base URL of the Vue app in production (no trailing slash). Used for absolute asset URLs
# (e.g. logo in layouts) when the app is served behind another host or port.
# In local dev, if unset, window.location.origin is used.
VITE_PUBLIC_APP_URL=http://localhost:5174

# API (see src/api/config.js)
VITE_API_URL=http://localhost:3000/api/v1
